# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# My-self
.history/*

# User data
/public/data/tenhou-stats.json

# Performance reports
lighthouse-report.*

# Test results
test-results/

# Firebase
firebase-debug.log

# Legacy files (unused)
supabase/

# Feed JSON & cache (now stored in GCS bucket basecamp-feeds, fetched at runtime)
public/data/*.json
# Apps thumbnails are uploaded to GCS by update-apps-feed; only placeholder.svg stays in git
public/images/apps/*.jpg
public/images/apps/*.png

# Local-only debug/agent state
.playwright-mcp/
.claude/
home-with-profile-links.png
prod-home-with-profile-links.png
